# QueryCraft works without server DB env vars for current shipped features.
# Optional for Test module backend (Phase 1+):

# Local Postgres example:
# TEST_DB_URL=postgresql://postgres:root@localhost:5432/querycraft_test?sslmode=disable

# Free hosted Postgres example (Neon/Supabase style):
# TEST_DB_URL=postgresql://username:password@ep-xxxx.ap-southeast-1.aws.neon.tech/querycraft_test?sslmode=require

RATE_LIMIT_REGISTER_MAX=3
RATE_LIMIT_REGISTER_WINDOW_MS=3600000

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
